#!/usr/bin/env sh
set -eu

# -----------------------
# helpers
# -----------------------
log() { printf '%s\n' "$*"; }
warn() { printf 'WARN: %s\n' "$*" >&2; }
die() { printf 'ERROR: %s\n' "$*" >&2; exit 1; }

command_exists() { command -v "$1" >/dev/null 2>&1; }

as_root() {
  if [ "$(id -u)" -eq 0 ]; then
    sh -c "$*"
  else
    if command_exists sudo; then
      sudo sh -c "$*"
    else
      die "需要 root 权限（写 /etc/docker、/usr/bin 等），但当前不是 root 且没有 sudo。请用 root 运行或安装 sudo。"
    fi
  fi
}

fetch() {
  url="$1"
  if command_exists curl; then
    curl -fsSL "$url"
  elif command_exists wget; then
    wget -qO- "$url"
  else
    die "缺少 curl 或 wget，无法下载：$url"
  fi
}

restart_docker() {
  if command_exists systemctl; then
    as_root "systemctl daemon-reload >/dev/null 2>&1 || true"
    as_root "systemctl enable docker >/dev/null 2>&1 || true"
    as_root "systemctl restart docker >/dev/null 2>&1 || systemctl restart docker.service >/dev/null 2>&1 || true"
  elif command_exists service; then
    as_root "service docker restart >/dev/null 2>&1 || service docker start >/dev/null 2>&1 || true"
  else
    warn "找不到 systemctl/service，无法自动重启 docker（可能需要手动启动 dockerd）。"
  fi
}

# -----------------------
# base path (robust)
# -----------------------
# shellcheck disable=SC2164
basepath="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"

# -----------------------
# perms
# -----------------------
# 让 src/*.py 可执行（如果存在）
if [ -d "$basepath/src" ] && ls "$basepath/src"/*.py >/dev/null 2>&1; then
  chmod +x "$basepath/src"/*.py || true
fi

# 让 src/shell 下脚本可执行（如果存在）
if [ -d "$basepath/src/shell" ]; then
  chmod -R +x "$basepath/src/shell" || true
fi

# share 权限：不建议 777，改为更安全的 a+rwX
if [ -d "$basepath/container/share" ]; then
  as_root "chmod -R a+rwX '$basepath/container/share' || true"
fi

# -----------------------
# docker install (official, no aliyun mirror)
# -----------------------
install_docker() {
  if command_exists docker; then
    log "docker already installed"
    return 0
  fi

  OS_ID=""
  OS_LIKE=""
  if [ -r /etc/os-release ]; then
    # shellcheck disable=SC1091
    . /etc/os-release
    OS_ID="${ID:-}"
    OS_LIKE="${ID_LIKE:-}"
  fi

  log "detected OS: ${OS_ID:-unknown} (like: ${OS_LIKE:-unknown})"

  # Alibaba Cloud Linux (alinux): use Docker CE repo for CentOS/RHEL path
  if [ "${OS_ID:-}" = "alinux" ]; then
    log "installing docker on alinux via CentOS/RHEL method..."

    PM=""
    if command_exists dnf; then
      PM="dnf"
    elif command_exists yum; then
      PM="yum"
    else
      die "alinux 上未找到 dnf/yum，无法安装 docker。"
    fi

    as_root "$PM -y makecache >/dev/null 2>&1 || true"
    as_root "$PM -y install yum-utils device-mapper-persistent-data lvm2 >/dev/null 2>&1 || true"

    # add docker-ce repo (centos)
    as_root "$PM-config-manager --add-repo https://download.docker.com/linux/centos/docker-ce.repo >/dev/null 2>&1 || true"

    # install docker engine
    as_root "$PM -y install docker-ce docker-ce-cli containerd.io"

    # start
    if command_exists systemctl; then
      as_root "systemctl enable --now docker"
    else
      as_root "service docker start || true"
    fi

    return 0
  fi

  # others: official convenience script
  log "installing docker via official get.docker.com script..."
  fetch "https://get.docker.com" | as_root "sh"
}

install_docker

# -----------------------
# docker daemon config (official; no registry-mirrors)
# -----------------------
as_root "mkdir -p /etc/docker"

# 只保留你原来需要的 insecure registry；如果你也不需要它，可以删掉这一段或把数组置空 []
as_root "cat > /etc/docker/daemon.json <<'EOF'
{
  \"insecure-registries\": [\"docker.dever.cc\"]
}
EOF"

restart_docker

# -----------------------
# symlinks to /usr/bin
# -----------------------
link_bin() {
  src="$1"
  name="$2"
  if [ ! -f "$src" ]; then
    warn "skip link: not found $src"
    return 0
  fi
  as_root "ln -sf '$src' '/usr/bin/$name' && chmod +x '/usr/bin/$name'"
}

link_bin "$basepath/src/dm.py"     "dm"
link_bin "$basepath/src/ds.py"     "ds"
link_bin "$basepath/src/dp.py"     "dp"
link_bin "$basepath/src/dpc.py"    "dpc"
link_bin "$basepath/src/dever.py"  "dever"
link_bin "$basepath/src/dever2.py" "dever2"
link_bin "$basepath/src/dgit.py"   "dgit"

# -----------------------
# verify
# -----------------------
if command_exists docker; then
  docker version || warn "docker 已安装但 docker version 失败（daemon 可能没启动/权限不足/需重新登录 docker 组）。"
else
  die "docker 安装失败。"
fi

log "install success!"